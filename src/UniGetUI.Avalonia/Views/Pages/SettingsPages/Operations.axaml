<UserControl x:Class="UniGetUI.Avalonia.Views.Pages.SettingsPages.Operations"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
             xmlns:vm="using:UniGetUI.Avalonia.ViewModels.Pages.SettingsPages"
             xmlns:settings="using:UniGetUI.Avalonia.Views.Controls.Settings"
             xmlns:t="using:UniGetUI.Avalonia.MarkupExtensions"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:DataType="vm:OperationsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Vertical">

            <settings:TranslatedTextBlock Text="Concurrency and execution"
                                          FontWeight="SemiBold"
                                          Margin="44,32,4,8"
                                          automation:AutomationProperties.HeadingLevel="2"/>

            <settings:ComboboxCard x:Name="ParallelOperationCount"
                                   SettingName="ParallelOperationCount"
                                   Text="{t:Translate Choose how many operations should be performed in parallel}"
                                   ValueChangedCommand="{Binding UpdateMaxOperationsCommand}"
                                   CornerRadius="8,8,0,0"/>

            <settings:CheckboxCard SettingName="MaintainSuccessfulInstalls"
                                   ForceInversion="True"
                                   Text="{t:Translate Clear successful operations from the operation list after a 5 second delay}"
                                   WarningText="{t:Translate Download operations are not affected by this setting}"
                                   BorderThickness="1,0,1,1"
                                   CornerRadius="0,0,8,8"/>

            <UserControl Height="16"/>

            <settings:CheckboxCard SettingName="KillProcessesThatRefuseToDie"
                                   Text="{t:Translate Try to kill the processes that refuse to close when requested to}"
                                   WarningText="{t:Translate You may lose unsaved data}"
                                   CornerRadius="8"/>

            <settings:TranslatedTextBlock Text="Automatic desktop shortcut remover"
                                          FontWeight="SemiBold"
                                          Margin="44,32,4,8"
                                          automation:AutomationProperties.HeadingLevel="2"/>

            <settings:CheckboxButtonCard x:Name="AskToDeleteNewDesktopShortcuts"
                                         SettingName="AskToDeleteNewDesktopShortcuts"
                                         CheckboxText="{t:Translate Text='Ask to delete desktop shortcuts created during an install or upgrade.'}"
                                         ButtonText="{t:Translate Manage shortcuts}"
                                         CornerRadius="8"/>

            <settings:TranslatedTextBlock Text="Related settings"
                                          FontWeight="SemiBold"
                                          Margin="44,32,4,8"
                                          automation:AutomationProperties.HeadingLevel="2"/>

            <settings:SettingsCard CornerRadius="8,8,0,0"
                                   IsClickEnabled="True"
                                   Command="{Binding NavigateToUpdatesCommand}"
                                   Header="{t:Translate Package update preferences}"
                                   Description="{t:Translate Text='Update check frequency, automatically install updates, etc.'}"/>

            <settings:SettingsCard BorderThickness="1,0,1,1"
                                   CornerRadius="0,0,8,8"
                                   IsClickEnabled="True"
                                   Command="{Binding NavigateToAdministratorCommand}"
                                   Header="{t:Translate Administrator rights and other dangerous settings}"
                                   Description="{t:Translate Text='Reduce UAC prompts, elevate installations by default, unlock certain dangerous features, etc.'}"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
