<?xml version="1.0" encoding="utf-8" ?>
<UserControl
  x:Class="UniGetUI.Controls.PackageRanking"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:widgets="using:UniGetUI.Interface.Widgets"
  mc:Ignorable="d"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!--  Header  -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
        <FontIcon FontSize="22" Glyph="&#xE8C4;" />
        <widgets:TranslatedTextBlock
          VerticalAlignment="Center"
          FontSize="16"
          FontWeight="SemiBold"
          Text="Most popular packages"
        />
      </StackPanel>
      <ComboBox
        x:Name="ManagerFilter"
        Grid.Column="1"
        MinWidth="140"
        SelectionChanged="ManagerFilter_SelectionChanged"
      />
    </Grid>

    <!--  Package list  -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="PackagesPanel" Orientation="Vertical" Spacing="4">
        <ProgressRing
          x:Name="LoadingRing"
          Width="32"
          Height="32"
          Margin="0,20,0,0"
          HorizontalAlignment="Center"
          IsActive="True"
        />
        <widgets:TranslatedTextBlock
          x:Name="ErrorText"
          HorizontalAlignment="Center"
          FontSize="13"
          Opacity="0.7"
          Text="Could not load rankings"
          Visibility="Collapsed"
        />
      </StackPanel>
    </ScrollViewer>

    <!--  Footer note  -->
    <widgets:TranslatedTextBlock
      Grid.Row="2"
      Margin="0,8,0,0"
      HorizontalAlignment="Center"
      FontSize="11"
      Opacity="0.6"
      Text="Rankings are based on anonymous install telemetry"
      WrappingMode="Wrap"
    />
  </Grid>
</UserControl>
